# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is listed in .gitignore.

FRED_API_KEY=your_fred_api_key_here
SEC_USER_AGENT=your_name(your_email@example.com)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=rail_macro_db
STB_APP_TOKEN=YOUR_STB_APP_TOKEN_HERE  # register at data.transportation.gov
FRA_USERNAME=your_fra_username_here    # register at safetydata.fra.dot.gov
FRA_PASSWORD=your_fra_password_here
FAF5_CSV_URL=https://faf.ornl.gov/faf5/data/download_files/FAF5.7.1_2017-2024.zip
